# Needoh - copy to .env (plain KEY=value only; no PowerShell in this file)

GROQ_API_KEY=
# Default: openai/gpt-oss-20b (reliable Groq tool JSON). Scout/Llama models may return tool_use_failed.
# NEEDOH_TOOL_OUTPUT_MAX_CHARS=10000 truncates tool results sent back to the LLM (reduces 413 TPM errors).
# DEFAULT_GROQ_MODEL=openai/gpt-oss-20b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
DEFAULT_PROVIDER=groq
AUTO_EXECUTE=false

# Optional: omit or leave empty to skip Tavily MCP (no web search tools)
TAVILY_API_KEY=
CONTEXT7_API_KEY=

# Comma-separated extra roots for filesystem MCP; if unset, uses current working directory only
# FILESYSTEM_ALLOWED_DIRS=C:\Projects\repo,D:\other

# CHROMA_PERSIST_DIR=./rag_server/chroma_store
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# RAG / HyDE (separate MCP subprocess; env is set in mcpclient/config.py).
# RAG_WARMUP=true preloads embeddings in the background (default off).
# RAG_LOG_TIMING=true prints phase timings to the rag process stderr.
# HYDE_ENABLED=true adds a Groq/Ollama step before retrieval (default off; more accurate but slower).
# RAG_EMBED_INIT_TIMEOUT_SEC=600 aborts stuck local model download/load (default 600).
# RAG_CLIENT_TIMEOUT_SEC=900 caps how long the main CLI waits on query_langchain_docs.
# RAG_HYDE_MAX_TOKENS=256
# RAG_TOP_K=5
# RAG_HYDE_TIMEOUT_SEC=120