@"
# Needoh - Environment Configuration Template
# Copy this file to .env and fill in your actual API keys

# ============================================================================
# LLM Provider API Keys
# ============================================================================

# Groq (cloud) - Get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Ollama (local) - Base URL for local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# Default Settings
# ============================================================================

# Which provider to use by default (groq or ollama)
DEFAULT_PROVIDER=groq

# Auto-execute tools without confirmation (true or false)
AUTO_EXECUTE=false

# ============================================================================
# MCP Server API Keys
# ============================================================================

# Tavily - Web search MCP server
# Get free key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Context7 - Documentation lookup MCP server
# Sign up at https://context7.com
CONTEXT7_API_KEY=your_context7_key_here

# ============================================================================
# RAG Server Configuration (optional)
# ============================================================================

# Path to ChromaDB storage (defaults to ./rag_server/chroma_store)
# CHROMA_PERSIST_DIR=./rag_server/chroma_store

# Embedding model (defaults to sentence-transformers/all-MiniLM-L6-v2)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunk size for document splitting (defaults to 800)
# CHUNK_SIZE=800

# Chunk overlap for document splitting (defaults to 200)
# CHUNK_OVERLAP=200
"@ | Out-File -FilePath ".env.example" -Encoding UTF8

Write-Host "✓ Created .env.example successfully!" -ForegroundColor Green