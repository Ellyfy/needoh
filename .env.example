# Needoh — copy to .env (plain KEY=value only; no PowerShell in this file)

GROQ_API_KEY=
# Default in code: openai/gpt-oss-20b. 3.3-70b often hits tool_use_failed; 3.1-70b was retired.
# DEFAULT_GROQ_MODEL=openai/gpt-oss-20b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
DEFAULT_PROVIDER=groq
AUTO_EXECUTE=false

# Optional: omit or leave empty to skip Tavily MCP (no web search tools)
TAVILY_API_KEY=
CONTEXT7_API_KEY=

# Comma-separated extra roots for filesystem MCP; if unset, uses current working directory only
# FILESYSTEM_ALLOWED_DIRS=C:\Projects\repo,D:\other

# CHROMA_PERSIST_DIR=./rag_server/chroma_store
# EMBEDDING_MODEL=all-MiniLM-L6-v2
